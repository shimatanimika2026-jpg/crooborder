# =============================================================================
# 中国協作ロボット日本委託組立業務Web管理システム
# 环境变量配置模板
# =============================================================================
#
# 使用说明：
#   cp .env.example .env
#   然后将下方占位值替换为真实值后重启应用。
#
# 模式说明：
#   ┌──────────────┬───────────────────────────────────────────────────┐
#   │ 运行模式      │ 说明                                               │
#   ├──────────────┼───────────────────────────────────────────────────┤
#   │ 演示模式      │ 不填写 VITE_SUPABASE_* 变量，应用使用本地演示数据    │
#   │              │ ⚠ 仅供页面预览，不得作为 MVP UAT 验收依据            │
#   ├──────────────┼───────────────────────────────────────────────────┤
#   │ UAT 验收模式  │ 必须填写真实 VITE_SUPABASE_URL 和 VITE_SUPABASE_  │
#   │              │ ANON_KEY，应用连接真实数据库，可作为验收依据          │
#   └──────────────┴───────────────────────────────────────────────────┘
# =============================================================================

# -----------------------------------------------------------------------------
# [必填] Supabase 数据库连接（UAT 验收模式必须填写）
# 获取方式：Supabase Dashboard → 选择项目 → Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# -----------------------------------------------------------------------------
# [自动] 应用内置配置（无需修改）
# -----------------------------------------------------------------------------
VITE_APP_NAME=中国協作ロボット日本委託組立業務Web管理システム
VITE_APP_VERSION=v345
